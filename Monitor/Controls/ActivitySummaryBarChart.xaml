<UserControl x:Class="SystemActivityTracker.Controls.ActivitySummaryBarChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SystemActivityTracker.Converters"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="400">
    
    <UserControl.Resources>
        <conv:Subtract10Converter x:Key="Subtract10Converter"/>
        <conv:Subtract8Converter x:Key="Subtract8Converter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Height="200" Margin="0,8,0,0">
        <!-- Debug TextBlock - Step 1: Verify data reaching control -->
        <Border Background="Yellow" Padding="5" HorizontalAlignment="Left" VerticalAlignment="Top" 
                CornerRadius="3" Margin="5" IsHitTestVisible="False" Panel.ZIndex="1">
            <StackPanel IsHitTestVisible="False">
                <TextBlock Text="DEBUG: Data Values" FontWeight="Bold" FontSize="10"/>
                <CheckBox Content="Use Sample Data (5h/1h/2h)" 
                         IsChecked="{Binding DebugUseSampleData, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                         FontSize="9" Margin="0,2,0,5"/>
                <TextBlock Text="{Binding TotalActiveSeconds, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='TotalActive: {0}'}" FontSize="9"/>
                <TextBlock Text="{Binding ActiveSeconds, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='Active: {0}'}" FontSize="9"/>
                <TextBlock Text="{Binding ManualSeconds, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='Manual: {0}'}" FontSize="9"/>
                <TextBlock Text="{Binding LockedSeconds, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='Locked: {0}'}" FontSize="9"/>
                <TextBlock Text="{Binding IdleSeconds, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='Idle: {0}'}" FontSize="9"/>
                <TextBlock Text="{Binding TargetSeconds, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='Target: {0}'}" FontSize="9"/>
            </StackPanel>
        </Border>
        
        <!-- Target Line with Label -->
        <Canvas Name="TargetLineCanvas" IsHitTestVisible="False">
            <Line Name="TargetLine" X1="60" Y1="{Binding TargetLinePosition, RelativeSource={RelativeSource AncestorType=UserControl}}" X2="400" Y2="{Binding TargetLinePosition, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                  Stroke="#10B981" StrokeThickness="3" Visibility="{Binding ShowTargetLine, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Rectangle Name="TargetLabelBackground" Canvas.Left="8" Canvas.Top="{Binding TargetLinePosition, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource Subtract10Converter}}" 
                     Width="35" Height="20" Fill="White" Stroke="#10B981" StrokeThickness="1" RadiusX="3" RadiusY="3"
                     Visibility="{Binding ShowTargetLine, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Text="{Binding TargetLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Canvas.Left="15" Canvas.Top="{Binding TargetLinePosition, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource Subtract8Converter}}" 
                     FontSize="11" Foreground="#10B981" FontWeight="Bold"
                     Visibility="{Binding ShowTargetLine, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Canvas>
        
        <!-- Chart -->
        <lvc:CartesianChart Name="ActivityChart" 
                           Background="Transparent" 
                           LegendLocation="Bottom"
                           Series="{Binding ChartSeries, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Hoverable="True"
                           DataTooltip="{x:Null}"
                           Panel.ZIndex="0">
            <lvc:CartesianChart.AxisY>
                <lvc:Axis LabelFormatter="{Binding AxisLabelFormatter, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                         MaxValue="{Binding YAxisMax, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Title=""
                         ShowLabels="True"
                         MinValue="0">
                    <lvc:Axis.Separator>
                        <lvc:Separator IsEnabled="True" StrokeThickness="1" Stroke="#E5E7EB" StrokeDashArray="2,2"/>
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisY>
            <lvc:CartesianChart.AxisX>
                <lvc:Axis Labels="{Binding CategoryLabels, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </lvc:CartesianChart.AxisX>
            
            <!-- Enhanced Custom Tooltip -->
            <lvc:CartesianChart.ToolTip>
                <ToolTip Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="12" MaxWidth="300">
                    <StackPanel>
                        <!-- Group A: Total Active (BIG font) -->
                        <TextBlock Text="{Binding TooltipTotalActive, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="16" FontWeight="Bold" 
                                  Foreground="#1F2937" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        
                        <!-- Separator Line -->
                        <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>
                        
                        <!-- Group B: Active Breakdown (tiny font) -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding TooltipActive, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TooltipManual, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- Separator Line -->
                        <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>
                        
                        <!-- Group C: Other (tiny font) -->
                        <StackPanel>
                            <TextBlock Text="{Binding TooltipIdle, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TooltipLocked, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ToolTip>
            </lvc:CartesianChart.ToolTip>
        </lvc:CartesianChart>
    </Grid>
</UserControl>
