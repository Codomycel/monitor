<UserControl x:Class="SystemActivityTracker.Controls.ActivityChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:conv="clr-namespace:SystemActivityTracker.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="400"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:BooleanToLegendLocationConverter x:Key="BoolToLegendLocationConverter"/>
        
        <!-- Theme-aware X-axis color brush -->
        <SolidColorBrush x:Key="XAxisBrush" Color="#666"/>
    </UserControl.Resources>

    <Grid Margin="4" MinHeight="70" MaxHeight="800">
        <!-- Dynamic Reference Line with Label (8h for daily, 40h for weekly) -->
        <Canvas Name="EightHourReferenceCanvas" IsHitTestVisible="False">
            <Line Name="EightHourLine" X1="50" Y1="{Binding EightHourLinePosition}" X2="200" Y2="{Binding EightHourLinePosition}" 
                  Stroke="#10B981" StrokeThickness="3"/>
            <Rectangle Name="EightHourLabelBackground" Canvas.Left="5" Canvas.Top="{Binding EightHourLabelPosition}" 
                     Width="35" Height="20" Fill="White" Stroke="#10B981" StrokeThickness="1" RadiusX="3" RadiusY="3"
                     Visibility="{Binding ShowReferenceLabel, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Name="EightHourLabel" Text="{Binding ReferenceLabelText}" Canvas.Left="12" Canvas.Top="{Binding EightHourLabelTextPosition}" 
                     FontSize="11" Foreground="#10B981" FontWeight="Bold"
                     Visibility="{Binding ShowReferenceLabel, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Canvas>
        
        <lvc:CartesianChart Name="ActivityChartControl" 
                           Background="Transparent" 
                           LegendLocation="{Binding ShowLegend, Converter={StaticResource BoolToLegendLocationConverter}}"
                           Series="{Binding ChartSeries}"
                           Hoverable="True"
                           DataTooltip="{x:Null}">
            <lvc:CartesianChart.AxisY>
                <lvc:Axis LabelFormatter="{Binding YAxisFormatter}" 
                         MaxValue="{Binding YAxisMax}"
                         Title=""
                         ShowLabels="True"
                         MinValue="0">
                    <lvc:Axis.Separator>
                        <lvc:Separator IsEnabled="True" StrokeThickness="1" Stroke="#E5E7EB" StrokeDashArray="2,2"/>
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisY>
            <lvc:CartesianChart.AxisX>
                <lvc:Axis Labels="{Binding XAxisLabels}" 
                         ShowLabels="True"
                         MinValue="0">
                    <lvc:Axis.Separator>
                        <lvc:Separator IsEnabled="True" 
                                       StrokeThickness="2" 
                                       Stroke="{Binding XAxisBrush}"
                                       StrokeDashArray=""/>
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisX>
            
            <!-- Enhanced Custom Tooltip -->
            <lvc:CartesianChart.ToolTip>
                <ToolTip Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="12" MaxWidth="300">
                    <StackPanel>
                        <!-- Group A: Total Active (BIG font) -->
                        <TextBlock Text="{Binding TooltipTotalActive}" FontSize="16" FontWeight="Bold" 
                                  Foreground="#1F2937" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        
                        <!-- Separator Line -->
                        <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>
                        
                        <!-- Group B: Active Breakdown (tiny font) -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding TooltipActive}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TooltipManual}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- Separator Line -->
                        <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>
                        
                        <!-- Group C: Other (tiny font) -->
                        <StackPanel>
                            <TextBlock Text="{Binding TooltipIdle}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TooltipLocked}" FontSize="10" Foreground="#6B7280" 
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ToolTip>
            </lvc:CartesianChart.ToolTip>
        </lvc:CartesianChart>
    </Grid>
</UserControl>
