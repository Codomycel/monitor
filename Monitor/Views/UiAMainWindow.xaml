<Window x:Class="SystemActivityTracker.Views.UiAMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SystemActivityTracker.Converters"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" 
        MinHeight="600" MinWidth="800"
        Background="{StaticResource BackgroundBrush}">
    

    <Window.Resources>
        <conv:DurationTextToMinutesConverter x:Key="DurationTextToMinutesConverter"/>
        <conv:SelectedDayMaxMinutesConverter x:Key="SelectedDayMaxMinutesConverter"/>
        <conv:SelectedDayBarWidthConverter x:Key="SelectedDayBarWidthConverter"/>
        <conv:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibilityConverter"/>
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <conv:DecimalHoursConverter x:Key="DecimalHoursConverter"/>
        <conv:Subtract10Converter x:Key="Subtract10Converter"/>
        <conv:Subtract8Converter x:Key="Subtract8Converter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" 
                Height="52" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource AppName}" Style="{StaticResource SubHeaderTextStyle}"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>

                <TextBlock Grid.Column="1" Text="{Binding SelectedDate, StringFormat={}{0:dd-MMM-yyyy}}"
                           Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center"
                           HorizontalAlignment="Center" TextAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                    <TextBlock Text="{Binding HeaderRunningTimerText}"
                               FontFamily="Consolas" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <TextBlock Text="UI:" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="UiModeComboBoxHeader" MinWidth="120" Height="30" Margin="0,0,10,0"
                              VerticalAlignment="Center" SelectionChanged="UiModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="UI A" Tag="UIA"/>
                        <ComboBoxItem Content="UI B" Tag="UIB"/>
                    </ComboBox>

                    <Border Width="74" Height="34" CornerRadius="6"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="15" Height="15" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="0"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="HeaderDot1Storyboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         From="0" To="-4" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="HeaderDot1Storyboard"/>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <Ellipse Width="15" Height="15" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="0"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="HeaderDot2Storyboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         From="0" To="-4" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="HeaderDot2Storyboard"/>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <Ellipse Width="15" Height="15">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="0"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="HeaderDot3Storyboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         From="0" To="-4" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.3">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="HeaderDot3Storyboard"/>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </StackPanel>
                    </Border>

                    <Button Content="Exit"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="10,4" Height="30" VerticalAlignment="Center"
                            Click="ExitButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content - Summary + Tabs -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="3*" MinWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- Left Pane: Summary Cards -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,12,0">
                <StackPanel>
                    <!-- Selected Day Card -->
                    <Border Background="White" CornerRadius="10" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1"
                            MinWidth="280" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>

                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Selected Day" Style="{StaticResource SectionHeaderTextStyle}" VerticalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                                <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="140"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Started" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDayStartText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Ended" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDayEndText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDayActiveTrackedText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Manual" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDayManualTasksText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Total Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedDayTotalActiveText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Idle" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedDayIdleText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Locked" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedDayLockedText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Selected Day Breakdown" Style="{StaticResource SecondaryTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <Grid Grid.Row="1" x:Name="SelectedDayBreakdownHost">
                                    <Grid.Tag>
                                        <MultiBinding Converter="{StaticResource SelectedDayMaxMinutesConverter}">
                                            <Binding Path="SelectedDayActiveTrackedText"/>
                                            <Binding Path="SelectedDayManualTasksText"/>
                                            <Binding Path="SelectedDayTotalActiveText"/>
                                            <Binding Path="SelectedDayIdleText"/>
                                            <Binding Path="SelectedDayLockedText"/>
                                        </MultiBinding>
                                    </Grid.Tag>

                                    <TextBlock Text="No data for selected day" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Visibility>
                                            <Binding ElementName="SelectedDayBreakdownHost" Path="Tag" Converter="{StaticResource ZeroToVisibilityConverter}"/>
                                        </TextBlock.Visibility>
                                    </TextBlock>

                                    <Grid Height="200" Margin="0,8,0,0">
                                    <!-- 8h Reference Line with Label -->
                                    <Canvas Name="EightHourReferenceCanvas" IsHitTestVisible="False">
                                        <Line Name="EightHourLine" X1="60" Y1="{Binding EightHourLinePosition}" X2="400" Y2="{Binding EightHourLinePosition}" 
                                              Stroke="#10B981" StrokeThickness="3"/>
                                        <Rectangle Name="EightHourLabelBackground" Canvas.Left="8" Canvas.Top="{Binding EightHourLinePosition, Converter={StaticResource Subtract10Converter}}" 
                                                 Width="35" Height="20" Fill="White" Stroke="#10B981" StrokeThickness="1" RadiusX="3" RadiusY="3"/>
                                        <TextBlock Name="EightHourLabel" Text="8h" Canvas.Left="15" Canvas.Top="{Binding EightHourLinePosition, Converter={StaticResource Subtract8Converter}}" 
                                                 FontSize="11" Foreground="#10B981" FontWeight="Bold"/>
                                    </Canvas>
                                    
                                    <lvc:CartesianChart Name="SelectedDayChart" 
                                                       Visibility="{Binding ElementName=SelectedDayBreakdownHost, Path=Tag, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}"
                                                       Background="Transparent" 
                                                       LegendLocation="Bottom"
                                                       Series="{Binding SelectedDaySeries}"
                                                       Hoverable="True"
                                                       DataTooltip="{x:Null}">
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis LabelFormatter="{Binding SelectedDayFormatter}" 
                                                     MaxValue="{Binding SelectedDayYAxisMax}"
                                                     Title=""
                                                     ShowLabels="True"
                                                     MinValue="0">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator IsEnabled="True" StrokeThickness="1" Stroke="#E5E7EB" StrokeDashArray="2,2"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Labels="{Binding SelectedDayLabels}" />
                                        </lvc:CartesianChart.AxisX>
                                        
                                        <!-- Enhanced Custom Tooltip -->
                                        <lvc:CartesianChart.ToolTip>
                                            <ToolTip Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="12" MaxWidth="300">
                                                <StackPanel>
                                                    <!-- Group A: Total Active (BIG font) -->
                                                    <TextBlock Text="{Binding TooltipTotalActive}" FontSize="16" FontWeight="Bold" 
                                                              Foreground="#1F2937" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                    
                                                    <!-- Separator Line -->
                                                    <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>
                                                    
                                                    <!-- Group B: Active Breakdown (tiny font) -->
                                                    <StackPanel Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding TooltipActive}" FontSize="10" Foreground="#6B7280" 
                                                                  TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding TooltipManual}" FontSize="10" Foreground="#6B7280" 
                                                                  TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Separator Line -->
                                                    <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>
                                                    
                                                    <!-- Group C: Other (tiny font) -->
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding TooltipIdle}" FontSize="10" Foreground="#6B7280" 
                                                                  TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding TooltipLocked}" FontSize="10" Foreground="#6B7280" 
                                                                  TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </ToolTip>
                                        </lvc:CartesianChart.ToolTip>
                                    </lvc:CartesianChart>
                                </Grid>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- This Week Card -->
                    <Border Background="White" CornerRadius="10" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1"
                            MinWidth="280" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="This Week" Style="{StaticResource SectionHeaderTextStyle}" Margin="0,0,0,8"
                                       FontWeight="SemiBold" FontSize="15"/>

                            <TextBlock Text="{Binding WeekNumberText}" Style="{StaticResource SecondaryTextStyle}"/>
                            <TextBlock Text="{Binding WeekRangeText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,2,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WeeklyTrackedActiveText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Manual" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WeeklyManualText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WeeklyTotalActiveText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Total Idle" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WeeklyTotalIdleText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Total Locked" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WeeklyTotalLockedText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Controls Card -->
                    <Border Background="White" CornerRadius="10" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1"
                            MinWidth="280" HorizontalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="Controls" Style="{StaticResource SectionHeaderTextStyle}" Margin="0,0,0,8"
                                       FontWeight="SemiBold" FontSize="15"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 1 -->
                                <Button Grid.Row="0" Grid.Column="0" Content="Start Tracking" Command="{Binding StartCommand}" 
                                        Margin="0,0,10,6" HorizontalAlignment="Stretch" >
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource HeaderBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                        Padding="10" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Ellipse Style="{StaticResource PulsingLargeStatusIndicatorStyle}"/>
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                                            <Setter Property="Text" Value="{DynamicResource TrackingLabelRunning}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsTrackingRunning}" Value="False">
                                                            <Setter Property="Text" Value="{DynamicResource TrackingLabelStopped}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Text" Value="{DynamicResource TrackingLabelUnknown}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Row 2 -->
                                <Button Grid.Row="1" Grid.Column="0" Content="Stop Tracking" Command="{Binding StopCommand}" 
                                        Margin="0,0,10,0" HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                                    <Setter Property="Background" Value="#DC2626"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTrackingRunning}" Value="False">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Grid.Row="1" Grid.Column="1" Content="Refresh Summary" Command="{Binding RefreshCommand}" 
                                        Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
                            </Grid>

                            <!-- Developer/Test section (keep existing visual design) -->
                            <Border Style="{StaticResource TestModeCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Developer / Test" Style="{StaticResource BodyTextStyle}" 
                                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <CheckBox Content="Test mode" Style="{StaticResource UIACheckBoxStyle}" 
                                              IsChecked="{Binding IsTestMode, Mode=TwoWay}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Enables Force Write Now button" Style="{StaticResource SecondaryTextStyle}" 
                                               FontSize="11" Margin="0,0,0,8"/>
                                    <Button Content="Force Write Now" Style="{StaticResource SecondaryButtonStyle}" 
                                            Command="{Binding ForceWriteNowCommand}" IsEnabled="{Binding IsTestMode}" 
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Pane: TabControl -->
            <TabControl Grid.Column="1" Style="{StaticResource UIATabControlStyle}" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                
                <!-- Application Usage Tab -->
                <TabItem Header="Application Usage" Style="{StaticResource UIATabItemStyle}">
                    <TabItem.Resources>
                        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource UIATextBoxStyle}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" Foreground="{TemplateBinding Foreground}"/>
                                            </Border>

                                            <TextBlock x:Name="Watermark"
                                                       Text="{TemplateBinding Tag}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Opacity="0.7"
                                                       Margin="{TemplateBinding Padding}"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"
                                                       Visibility="Collapsed"/>
                                        </Grid>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Watermark" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style x:Key="IconOnlyButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="MinWidth" Value="26"/>
                            <Setter Property="MinHeight" Value="26"/>
                            <Setter Property="Width" Value="26"/>
                            <Setter Property="Height" Value="26"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#11000000"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#22000000"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabItem.Resources>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Application Usage" Style="{StaticResource SectionHeaderTextStyle}"/>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding TodayAppUsage}" Style="{StaticResource UIADataGridStyle}"
                                          VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0"
                                          CanUserSortColumns="True"
                                          IsReadOnly="True">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource UIADataGridColumnHeaderStyle}"/>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource UIADataGridRowStyle}"/>
                                    </DataGrid.RowStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource UIADataGridCellStyle}"/>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="App / Process" Binding="{Binding ProcessName}" Width="2*" SortMemberPath="ProcessName">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Active Time" Binding="{Binding ActiveDurationText, Mode=OneWay}" Width="1*" SortMemberPath="ActiveDuration"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Margin="0" Padding="6">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDayDetailsMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <TextBlock Text="Manual Tasks" Style="{StaticResource SectionHeaderTextStyle}"/>

                                <TextBox Style="{StaticResource WatermarkTextBoxStyle}" Margin="0,2,0,2" Tag="Task name"
                                         Text="{Binding ManualTaskName, UpdateSourceTrigger=PropertyChanged}"/>

                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Style="{StaticResource WatermarkTextBoxStyle}" Margin="0,0,6,0" Tag="HH"
                                             Text="{Binding ManualHours, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource WatermarkTextBoxStyle}" Margin="0,0,6,0" Tag="MM"
                                             Text="{Binding ManualMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource WatermarkTextBoxStyle}" Tag="SS"
                                             Text="{Binding ManualSeconds, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Button Grid.Column="3" Margin="6,0,0,0" Style="{StaticResource IconOnlyButtonStyle}"
                                            Command="{Binding PrimaryManualTaskCommand}" ToolTip="Add / Save">
                                        <TextBlock Text="{Binding PrimaryManualTaskGlyph}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Tip: Values auto-normalize (e.g., 90 seconds becomes 1m 30s)." Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,2"/>

                                <DataGrid ItemsSource="{Binding ManualTasks}" SelectedItem="{Binding SelectedManualTask, Mode=TwoWay}"
                                          Style="{StaticResource UIADataGridStyle}"
                                          VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,2"
                                          CanUserSortColumns="True" IsReadOnly="True">
                                    <DataGrid.RowHeight>40</DataGrid.RowHeight>
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource UIADataGridColumnHeaderStyle}"/>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource UIADataGridRowStyle}"/>
                                    </DataGrid.RowStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource UIADataGridCellStyle}"/>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="72" MinWidth="72" CanUserSort="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Margin="2,0" CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconOnlyButtonStyle}">
                                                                <Setter Property="ToolTip" Value="Edit"/>
                                                                <Setter Property="Command" Value="{Binding DataContext.BeginEditManualTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsManualEditMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                                                        <Setter Property="Command" Value="{Binding DataContext.CancelManualTaskEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                                                        <Setter Property="CommandParameter" Value="{x:Null}"/>
                                                                        <Setter Property="ToolTip" Value="Cancel"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="{Binding DataContext.ManualRowActionGlyph, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="18"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Task" Binding="{Binding TaskName}" Width="2*" SortMemberPath="TaskName">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Duration" Binding="{Binding DurationText, Mode=OneWay}" Width="1*" SortMemberPath="TotalSeconds"/>

                                        <DataGridTemplateColumn Width="80" MinWidth="80" CanUserSort="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.DeleteManualTaskRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Margin>
                                                            <Thickness>2,0,2,0</Thickness>
                                                        </Button.Margin>
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconOnlyButtonStyle}">
                                                                <Setter Property="ToolTip" Value="Delete"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsManualEditMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>

                                                        <TextBlock Text="{Binding DataContext.ManualDeleteGlyph, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="18"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Manual:" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding ManualTotalText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,14,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Weekly Overview Tab -->
                <TabItem Header="Weekly Overview" Style="{StaticResource UIATabItemStyle}">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Weekly Overview Header -->
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Weekly Overview" Style="{StaticResource SectionHeaderTextStyle}" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Text="Week start:" Style="{StaticResource BodyTextStyle}" 
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <DatePicker SelectedDate="{Binding WeekStartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                Width="140" Margin="0,0,8,0"/>
                                    <Button Content="Load" Style="{StaticResource SecondaryButtonStyle}" 
                                            Command="{Binding LoadWeeklyCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Weekly Overview DataGrid -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                            <DataGrid ItemsSource="{Binding WeeklySummaries}" Style="{StaticResource UIADataGridStyle}"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource UIADataGridColumnHeaderStyle}"/>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource UIADataGridRowStyle}"/>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource UIADataGridCellStyle}"/>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, Mode=OneWay, StringFormat={}{0:dd-MMM-yyyy}}" Width="1*" SortMemberPath="Date"/>
                                    <DataGridTextColumn Header="Active" Binding="{Binding ActiveDurationText, Mode=OneWay}" Width="1*" SortMemberPath="ActiveDuration"/>
                                    <DataGridTextColumn Header="Manual" Binding="{Binding ManualTaskDurationText, Mode=OneWay}" Width="1*" SortMemberPath="ManualTaskDuration"/>
                                    <DataGridTextColumn Header="Total Active" Binding="{Binding TotalActiveDurationText, Mode=OneWay}" Width="1*" SortMemberPath="TotalActiveDuration"/>
                                    <DataGridTextColumn Header="Idle" Binding="{Binding IdleDurationText, Mode=OneWay}" Width="1*" SortMemberPath="IdleDuration"/>
                                    <DataGridTextColumn Header="Locked" Binding="{Binding LockedDurationText, Mode=OneWay}" Width="1*" SortMemberPath="LockedDuration"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Weekly Totals -->
                        <Grid Grid.Row="2" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource SuccessBrush}" CornerRadius="6,0,0,6"/>
                                    <StackPanel Grid.Column="1" Margin="14" VerticalAlignment="Center">
                                        <TextBlock Text="Total Active" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding WeeklyTotalActiveText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BorderBrush}" CornerRadius="6,0,0,6"/>
                                    <StackPanel Grid.Column="1" Margin="14" VerticalAlignment="Center">
                                        <TextBlock Text="Idle" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding WeeklyTotalIdleText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource ErrorBrush}" CornerRadius="6,0,0,6"/>
                                    <StackPanel Grid.Column="1" Margin="14" VerticalAlignment="Center">
                                        <TextBlock Text="Locked" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding WeeklyTotalLockedText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Monthly Usage Tab -->
                <TabItem Header="Monthly Usage" Style="{StaticResource UIATabItemStyle}">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Monthly Usage" Style="{StaticResource SectionHeaderTextStyle}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Active:" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding MonthlyActiveTrackedText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,14,0"/>
                                        <TextBlock Text="Manual (Tasks):" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding MonthlyManualTasksText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,14,0"/>
                                        <TextBlock Text="Total Active:" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding MonthlyTotalActiveText}" Style="{StaticResource SecondaryTextStyle}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="Month:" Style="{StaticResource BodyTextStyle}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <DatePicker SelectedDate="{Binding SelectedMonth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="140" Margin="0,0,8,0"/>
                                    <Button Content="Load" Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding LoadMonthlyUsageCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <TextBlock Text="No data for selected month"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMonthlyUsageEmpty}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <DataGrid ItemsSource="{Binding MonthlyAppUsage}"
                                          VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0"
                                          CanUserSortColumns="True"
                                          IsReadOnly="True">
                                    <DataGrid.Style>
                                        <Style TargetType="DataGrid" BasedOn="{StaticResource UIADataGridStyle}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMonthlyUsageEmpty}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Style>

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource UIADataGridColumnHeaderStyle}"/>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource UIADataGridRowStyle}"/>
                                    </DataGrid.RowStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource UIADataGridCellStyle}"/>
                                    </DataGrid.CellStyle>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="App / Process" Binding="{Binding ProcessName}" Width="2*" SortMemberPath="ProcessName">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Total Active" Binding="{Binding TotalActiveText, Mode=OneWay}" Width="1*" SortMemberPath="TotalActive"/>
                                        <DataGridTextColumn Header="Total Idle" Binding="{Binding TotalIdleText, Mode=OneWay}" Width="1*" SortMemberPath="TotalIdle"/>
                                        <DataGridTextColumn Header="Total Locked" Binding="{Binding TotalLockedText, Mode=OneWay}" Width="1*" SortMemberPath="TotalLocked"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Last Crash Tab -->
                <TabItem Header="Last Crash" Style="{StaticResource UIATabItemStyle}">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Diagnostics" Style="{StaticResource SectionHeaderTextStyle}"/>
                                    <TextBlock Text="{Binding LastCrash.CrashSummary}" Style="{StaticResource SecondaryTextStyle}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding LastCrash.CrashLogPath}" Style="{StaticResource SecondaryTextStyle}" Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="Refresh" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                                            Command="{Binding LastCrash.RefreshCommand}"/>
                                    <Button Content="Open Log" Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding LastCrash.OpenLogCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <TextBlock Text="No crash data found."
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LastCrash.HasCrashData}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LastCrash.HasCrashData}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>

                                    <TextBox Text="{Binding LastCrash.CrashDetailsText, Mode=OneWay}" IsReadOnly="True"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             BorderThickness="0" Background="Transparent"
                                             VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled"
                                             FontFamily="Consolas" FontSize="12" Padding="12"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Settings Tab -->
                <TabItem Header="Settings" Style="{StaticResource UIATabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                        <StackPanel>

                            <!-- Settings Card -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Settings" Style="{StaticResource SectionHeaderTextStyle}"/>
                                    
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="UI:" Style="{StaticResource BodyTextStyle}" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Width="80"/>
                                        <ComboBox x:Name="UiModeComboBox" Grid.Column="1" MinWidth="140" SelectionChanged="UiModeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="UI A" Tag="UIA"/>
                                            <ComboBoxItem Content="UI B" Tag="UIB"/>
                                        </ComboBox>
                                    </Grid>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="Idle (min):" Style="{StaticResource BodyTextStyle}" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Width="80"/>
                                        <TextBox Grid.Column="1" Style="{StaticResource UIATextBoxStyle}" Margin="0,0,0,6"
                                                 Text="{Binding IdleThresholdMinutes, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10"
                                                   Text="Marks you as idle after this many minutes without keyboard/mouse input."/>
                                        
                                        <TextBlock Grid.Row="2" Text="Poll (sec):" Style="{StaticResource BodyTextStyle}" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Width="80"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource UIATextBoxStyle}" Margin="0,0,0,6"
                                                 Text="{Binding PollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10"
                                                   Text="How often tracking checks the active window / idle state (lower = more frequent)."/>
                                        
                                        <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="Enable live refresh" 
                                                  Style="{StaticResource UIACheckBoxStyle}" Margin="0,0,0,6"
                                                  IsChecked="{Binding EnableLiveRefresh, Mode=TwoWay}"/>

                                        <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10"
                                                   Text="Automatically refreshes the summary while tracking is running and the selected date is today."/>
                                        
                                        <TextBlock Grid.Row="6" Text="Refresh (sec):" Style="{StaticResource BodyTextStyle}" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Width="80"/>
                                        <TextBox Grid.Row="6" Grid.Column="1" Style="{StaticResource UIATextBoxStyle}" Margin="0,0,0,6"
                                                 Text="{Binding LiveRefreshIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,12"
                                                   Text="Interval for live refresh. Applied after clicking Save Settings."/>

                                        <TextBlock Grid.Row="8" Text="Crash retention (days):" Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Width="140"/>
                                        <TextBox Grid.Row="8" Grid.Column="1" Style="{StaticResource UIATextBoxStyle}" Margin="0,0,0,6"
                                                 Text="{Binding CrashLogRetentionDays, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="9" Text="Crash max size (MB):" Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" Width="140"/>
                                        <TextBox Grid.Row="9" Grid.Column="1" Style="{StaticResource UIATextBoxStyle}" Margin="0,0,0,6"
                                                 Text="{Binding CrashLogMaxSizeMB, UpdateSourceTrigger=PropertyChanged}"/>

                                        <Button Grid.Row="10" Grid.ColumnSpan="2" Content="Clear crash logs"
                                                Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                                Command="{Binding ClearCrashLogsCommand}"/>
                                        
                                        <Button Grid.Row="11" Grid.ColumnSpan="2" Content="Save Settings" 
                                                Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"
                                                Command="{Binding SaveSettingsCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
