<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SystemActivityTracker.Converters"
             xmlns:controls="clr-namespace:SystemActivityTracker.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:DurationTextToMinutesConverter x:Key="DurationTextToMinutesConverter"/>
        <conv:SelectedDayMaxMinutesConverter x:Key="SelectedDayMaxMinutesConverter"/>
        <conv:SelectedDayBarWidthConverter x:Key="SelectedDayBarWidthConverter"/>
        <conv:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibilityConverter"/>
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Height="52" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource AppName}" Style="{StaticResource SubHeaderTextStyle}"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>

                <TextBlock Grid.Column="1" Text="{Binding SelectedDate, StringFormat={}{0:dd-MMM-yyyy}}"
                           Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center"
                           HorizontalAlignment="Center" TextAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                    <controls:HeaderWatchTimer/>

                    <Border Width="74" Height="34" CornerRadius="6"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="15" Height="15" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="HeaderDot1Storyboard">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                             From="0" To="-4" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <SineEase EasingMode="EaseInOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="HeaderDot1Storyboard"/>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <Ellipse Width="15" Height="15" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="HeaderDot2Storyboard">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                             From="0" To="-4" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <SineEase EasingMode="EaseInOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="HeaderDot2Storyboard"/>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <Ellipse Width="15" Height="15">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTrackingRunning}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="HeaderDot3Storyboard">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                             From="0" To="-4" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.3">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <SineEase EasingMode="EaseInOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="HeaderDot3Storyboard"/>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ItemsControl HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Stretch" ItemWidth="320"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="Border">
                            <Setter Property="Margin" Value="0,0,12,12"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <Border Background="White" CornerRadius="10" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1"
                            MinWidth="320" HorizontalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>

                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Selected Day" Style="{StaticResource SectionHeaderTextStyle}" VerticalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                                <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="140"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Started" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDayStartText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Ended" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDayEndText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Leave" FontSize="13" Margin="0,3,12,3"
                                           Visibility="{Binding HasSelectedDayLeave, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDayLeaveSummaryText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"
                                           Visibility="{Binding HasSelectedDayLeave, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Expected" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDayExpectedHoursText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedDayActiveTrackedText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Manual" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedDayManualTasksText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Total Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedDayTotalActiveText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Idle" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedDayIdleText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Locked" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedDayLockedText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.Resources>
                                    <Style x:Key="SelectedDayBreakdownBarRowStyle" TargetType="Border">
                                        <Setter Property="Height" Value="8"/>
                                        <Setter Property="CornerRadius" Value="4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </Grid.Resources>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Selected Day Breakdown" Style="{StaticResource SecondaryTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <Grid Grid.Row="1" x:Name="SelectedDayBreakdownHost">
                                    <Grid.Tag>
                                        <MultiBinding Converter="{StaticResource SelectedDayMaxMinutesConverter}">
                                            <Binding Path="SelectedDayActiveTrackedText"/>
                                            <Binding Path="SelectedDayManualTasksText"/>
                                            <Binding Path="SelectedDayTotalActiveText"/>
                                            <Binding Path="SelectedDayIdleText"/>
                                            <Binding Path="SelectedDayLockedText"/>
                                        </MultiBinding>
                                    </Grid.Tag>

                                    <TextBlock Text="No data for selected day" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Left">
                                        <TextBlock.Visibility>
                                            <Binding ElementName="SelectedDayBreakdownHost" Path="Tag" Converter="{StaticResource ZeroToVisibilityConverter}"/>
                                        </TextBlock.Visibility>
                                    </TextBlock>

                                    <Grid Visibility="{Binding ElementName=SelectedDayBreakdownHost, Path=Tag, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SelectedDayActiveTrackedText, StringFormat=Active {0}}" FontSize="12"/>
                                        <Grid Grid.Row="0" Grid.Column="2" x:Name="SelectedDayChartAreaA" Height="10" VerticalAlignment="Center">
                                            <Border Background="#EEF2FF" Height="8" CornerRadius="4"/>
                                            <Border Background="#2563EB" Style="{StaticResource SelectedDayBreakdownBarRowStyle}" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource SelectedDayBarWidthConverter}">
                                                        <Binding Path="SelectedDayActiveTrackedText"/>
                                                        <Binding ElementName="SelectedDayBreakdownHost" Path="Tag"/>
                                                        <Binding ElementName="SelectedDayChartAreaA" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SelectedDayManualTasksText, StringFormat=Manual {0}}" FontSize="12" Margin="0,4,0,0"/>
                                        <Grid Grid.Row="1" Grid.Column="2" x:Name="SelectedDayChartAreaB" Height="10" VerticalAlignment="Center" Margin="0,4,0,0">
                                            <Border Background="#ECFDF5" Height="8" CornerRadius="4"/>
                                            <Border Background="#10B981" Style="{StaticResource SelectedDayBreakdownBarRowStyle}" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource SelectedDayBarWidthConverter}">
                                                        <Binding Path="SelectedDayManualTasksText"/>
                                                        <Binding ElementName="SelectedDayBreakdownHost" Path="Tag"/>
                                                        <Binding ElementName="SelectedDayChartAreaB" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding SelectedDayTotalActiveText, StringFormat=Total Active {0}}" FontSize="12" Margin="0,4,0,0"/>
                                        <Grid Grid.Row="2" Grid.Column="2" x:Name="SelectedDayChartAreaC" Height="10" VerticalAlignment="Center" Margin="0,4,0,0">
                                            <Border Background="#FEF3C7" Height="8" CornerRadius="4"/>
                                            <Border Background="#F59E0B" Style="{StaticResource SelectedDayBreakdownBarRowStyle}" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource SelectedDayBarWidthConverter}">
                                                        <Binding Path="SelectedDayTotalActiveText"/>
                                                        <Binding ElementName="SelectedDayBreakdownHost" Path="Tag"/>
                                                        <Binding ElementName="SelectedDayChartAreaC" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding SelectedDayIdleText, StringFormat=Idle {0}}" FontSize="12" Margin="0,4,0,0"/>
                                        <Grid Grid.Row="3" Grid.Column="2" x:Name="SelectedDayChartAreaD" Height="10" VerticalAlignment="Center" Margin="0,4,0,0">
                                            <Border Background="#F3F4F6" Height="8" CornerRadius="4"/>
                                            <Border Background="#6B7280" Style="{StaticResource SelectedDayBreakdownBarRowStyle}" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource SelectedDayBarWidthConverter}">
                                                        <Binding Path="SelectedDayIdleText"/>
                                                        <Binding ElementName="SelectedDayBreakdownHost" Path="Tag"/>
                                                        <Binding ElementName="SelectedDayChartAreaD" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding SelectedDayLockedText, StringFormat=Locked {0}}" FontSize="12" Margin="0,4,0,0"/>
                                        <Grid Grid.Row="4" Grid.Column="2" x:Name="SelectedDayChartAreaE" Height="10" VerticalAlignment="Center" Margin="0,4,0,0">
                                            <Border Background="#FEE2E2" Height="8" CornerRadius="4"/>
                                            <Border Background="#EF4444" Style="{StaticResource SelectedDayBreakdownBarRowStyle}" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource SelectedDayBarWidthConverter}">
                                                        <Binding Path="SelectedDayLockedText"/>
                                                        <Binding ElementName="SelectedDayBreakdownHost" Path="Tag"/>
                                                        <Binding ElementName="SelectedDayChartAreaE" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1"
                            MinWidth="320" HorizontalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                        </Border.Effect>

                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding WeekReportHeaderText}" Style="{StaticResource SectionHeaderTextStyle}"
                                           FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Command="{Binding PreviousWeekCommand}" Style="{StaticResource IconOnlyButtonStyle}"
                                            ToolTip="Previous week" Margin="0,0,4,0">
                                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </Button>
                                    <Button Command="{Binding NextWeekCommand}" Style="{StaticResource IconOnlyButtonStyle}"
                                            ToolTip="Next week" Margin="0,0,4,0">
                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </Button>
                                    <Button Command="{Binding CurrentWeekCommand}" Content="This Week"
                                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" FontSize="11" Margin="0,0,4,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding SelectedWeekRangeText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,2,0,8"/>

                            <TextBlock Text="{Binding WeekLeaveSummaryText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,4"
                                       Visibility="{Binding HasWeekLeave, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <TextBlock Text="{Binding WeekExpectedHoursText}" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Select week:" Style="{StaticResource SecondaryTextStyle}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker SelectedDate="{Binding WeekPickerDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="130" ToolTip="Pick any date to jump to that week"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WeeklyTrackedActiveText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Manual" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WeeklyManualText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Active" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WeeklyTotalActiveText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Total Idle" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WeeklyTotalIdleText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Total Locked" FontSize="13" Margin="0,3,12,3"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WeeklyTotalLockedText}" FontSize="13" Margin="0,3,0,3"
                                           HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </ItemsControl>
            </Border>

            <TabControl Grid.Row="1" Style="{StaticResource UIATabControlStyle}" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                <TabItem Header="Application Usage" Style="{StaticResource UIATabItemStyle}">
                    <ContentPresenter Content="{Binding}"/>
                </TabItem>
                <TabItem Header="Weekly Overview" Style="{StaticResource UIATabItemStyle}">
                    <ContentPresenter Content="{Binding}"/>
                </TabItem>
                <TabItem Header="Monthly Usage" Style="{StaticResource UIATabItemStyle}">
                    <ContentPresenter Content="{Binding}"/>
                </TabItem>
                <TabItem Header="Last Crash" Style="{StaticResource UIATabItemStyle}">
                    <ContentPresenter Content="{Binding}"/>
                </TabItem>
                <TabItem Header="Settings" Style="{StaticResource UIATabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                        <StackPanel>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Settings" Style="{StaticResource SectionHeaderTextStyle}"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="UI:" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" Margin="0,0,8,0" Width="80"/>
                                        <ComboBox Grid.Column="1" MinWidth="140">
                                            <ComboBoxItem Content="UI A" Tag="UIA"/>
                                            <ComboBoxItem Content="UI B" Tag="UIB"/>
                                        </ComboBox>
                                    </Grid>

                                    <TextBlock Text="Idle (min):" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" Margin="0,0,8,0" Width="80"/>
                                    <TextBox Style="{StaticResource UIATextBoxStyle}" Margin="0,0,0,6"
                                             Text="{Binding IdleThresholdMinutes, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Button Content="Save Settings" Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Stretch" Command="{Binding SaveSettingsCommand}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
