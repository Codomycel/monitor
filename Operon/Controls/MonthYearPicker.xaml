<UserControl x:Class="SystemActivityTracker.Controls.MonthYearPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="36" d:DesignWidth="140">

    <UserControl.Resources>
        <Style x:Key="MonthYearButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MonthYearNavButtonStyle" TargetType="Button" BasedOn="{StaticResource MonthYearButtonStyle}">
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
    <Button x:Name="PickerButton" Width="140" Height="36"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Center"
            Click="PickerButton_Click">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border x:Name="RootBorder" Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding DisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <TextBlock DockPanel.Dock="Right" Text="▾" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Margin="0,0,12,0"/>
                    </DockPanel>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="RootBorder" Property="BorderBrush" Value="#CBD5E1"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>

    <Popup x:Name="PickerPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
           PlacementTarget="{Binding ElementName=PickerButton}"
           Opened="PickerPopup_Opened" Closed="PickerPopup_Closed">
        <Border Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.12"/>
            </Border.Effect>
            <StackPanel>
                <!-- Year navigation -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="‹" Style="{StaticResource MonthYearNavButtonStyle}"
                            FontSize="18" Width="32" Height="32"
                            Click="YearPrev_Click"/>
                    <TextBlock Grid.Column="1" x:Name="YearText" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="›" Style="{StaticResource MonthYearNavButtonStyle}"
                            FontSize="18" Width="32" Height="32"
                            Click="YearNext_Click"/>
                </Grid>
                <!-- Month grid (3x4) -->
                <UniformGrid Columns="3" Rows="4">
                    <Button Content="Jan" Style="{StaticResource MonthYearButtonStyle}" Tag="1" Click="Month_Click"/>
                    <Button Content="Feb" Style="{StaticResource MonthYearButtonStyle}" Tag="2" Click="Month_Click"/>
                    <Button Content="Mar" Style="{StaticResource MonthYearButtonStyle}" Tag="3" Click="Month_Click"/>
                    <Button Content="Apr" Style="{StaticResource MonthYearButtonStyle}" Tag="4" Click="Month_Click"/>
                    <Button Content="May" Style="{StaticResource MonthYearButtonStyle}" Tag="5" Click="Month_Click"/>
                    <Button Content="Jun" Style="{StaticResource MonthYearButtonStyle}" Tag="6" Click="Month_Click"/>
                    <Button Content="Jul" Style="{StaticResource MonthYearButtonStyle}" Tag="7" Click="Month_Click"/>
                    <Button Content="Aug" Style="{StaticResource MonthYearButtonStyle}" Tag="8" Click="Month_Click"/>
                    <Button Content="Sep" Style="{StaticResource MonthYearButtonStyle}" Tag="9" Click="Month_Click"/>
                    <Button Content="Oct" Style="{StaticResource MonthYearButtonStyle}" Tag="10" Click="Month_Click"/>
                    <Button Content="Nov" Style="{StaticResource MonthYearButtonStyle}" Tag="11" Click="Month_Click"/>
                    <Button Content="Dec" Style="{StaticResource MonthYearButtonStyle}" Tag="12" Click="Month_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Popup>
    </Grid>
</UserControl>
