<UserControl x:Class="SystemActivityTracker.Controls.HorizontalActivityBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="20" d:DesignWidth="120"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Height="12" VerticalAlignment="Center">
        <!-- Empty state background (shown when no data) -->
        <Border Background="{Binding EmptyBackgroundBrush}" 
                CornerRadius="3"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}"/>

        <!-- Horizontal stacked bar (only visible when HasData is true) -->
        <Grid Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <!-- Active segment -->
                <ColumnDefinition Width="{Binding ActiveWidth, Mode=OneWay}" x:Name="ActiveColumn"/>
                <!-- Manual segment -->
                <ColumnDefinition Width="{Binding ManualWidth, Mode=OneWay}" x:Name="ManualColumn"/>
                <!-- Idle segment -->
                <ColumnDefinition Width="{Binding IdleWidth, Mode=OneWay}" x:Name="IdleColumn"/>
                <!-- Locked segment -->
                <ColumnDefinition Width="{Binding LockedWidth, Mode=OneWay}" x:Name="LockedColumn"/>
            </Grid.ColumnDefinitions>

            <!-- Active segment -->
            <Border Grid.Column="0"
                    Background="{Binding ActiveBrush}"
                    Visibility="{Binding ShowActive, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3,0,0,3"/>

            <!-- Manual segment -->
            <Border Grid.Column="1"
                    Background="{Binding ManualBrush}"
                    Visibility="{Binding ShowManual, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Idle segment -->
            <Border Grid.Column="2"
                    Background="{Binding IdleBrush}"
                    Visibility="{Binding ShowIdle, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Locked segment (rightmost, rounded right corners) -->
            <Border Grid.Column="3"
                    Background="{Binding LockedBrush}"
                    Visibility="{Binding ShowLocked, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="0,3,3,0"/>

            <!-- When Manual is first visible segment (no Active) -->
            <Border Grid.Column="1"
                    Background="{Binding ManualBrush}"
                    Visibility="{Binding ShowManualNoActive, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3,0,0,3"/>

            <!-- When Idle is first visible segment (no Active/Manual) -->
            <Border Grid.Column="2"
                    Background="{Binding IdleBrush}"
                    Visibility="{Binding ShowIdleFirst, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3,0,0,3"/>

            <!-- When Locked is first visible segment -->
            <Border Grid.Column="3"
                    Background="{Binding LockedBrush}"
                    Visibility="{Binding ShowLockedFirst, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3"/>

            <!-- When only Active is visible -->
            <Border Grid.Column="0"
                    Background="{Binding ActiveBrush}"
                    Visibility="{Binding ShowOnlyActive, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3"/>

            <!-- When only Manual is visible -->
            <Border Grid.Column="1"
                    Background="{Binding ManualBrush}"
                    Visibility="{Binding ShowOnlyManual, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3"/>

            <!-- When only Idle is visible -->
            <Border Grid.Column="2"
                    Background="{Binding IdleBrush}"
                    Visibility="{Binding ShowOnlyIdle, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3"/>

            <!-- When only Locked is visible -->
            <Border Grid.Column="3"
                    Background="{Binding LockedBrush}"
                    Visibility="{Binding ShowOnlyLocked, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="3"/>

            <!-- Active+Manual ending (Active start, Manual end) -->
            <Border Grid.Column="1"
                    Background="{Binding ManualBrush}"
                    Visibility="{Binding ShowManualEnd, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="0,3,3,0"/>

            <!-- Active+Manual+Idle ending -->
            <Border Grid.Column="2"
                    Background="{Binding IdleBrush}"
                    Visibility="{Binding ShowIdleEnd, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="0,3,3,0"/>

            <!-- Any combination ending with Locked -->
            <Border Grid.Column="3"
                    Background="{Binding LockedBrush}"
                    Visibility="{Binding ShowLockedAlwaysEnd, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="0,3,3,0"/>
        </Grid>

        <!-- Tooltip container (covers entire bar area) -->
        <Border Background="Transparent" 
                ToolTipService.ShowDuration="30000"
                ToolTipService.InitialShowDelay="100">
            <Border.ToolTip>
                <ToolTip Background="White" 
                         BorderBrush="#D1D5DB" 
                         BorderThickness="1" 
                         Padding="12" 
                         MaxWidth="280">
                    <StackPanel>
                        <!-- Total Active (BIG font) -->
                        <TextBlock Text="{Binding TooltipTotalActive}" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#1F2937" 
                                   TextWrapping="Wrap" 
                                   Margin="0,0,0,8"/>

                        <!-- Separator -->
                        <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>

                        <!-- Active and Manual -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding TooltipActive}" 
                                       FontSize="10" 
                                       Foreground="#6B7280" 
                                       TextWrapping="Wrap" 
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TooltipManual}" 
                                       FontSize="10" 
                                       Foreground="#6B7280" 
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Separator Height="1" Background="#E5E7EB" Margin="0,0,0,8"/>

                        <!-- Idle and Locked -->
                        <StackPanel>
                            <TextBlock Text="{Binding TooltipIdle}" 
                                       FontSize="10" 
                                       Foreground="#6B7280" 
                                       TextWrapping="Wrap" 
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding TooltipLocked}" 
                                       FontSize="10" 
                                       Foreground="#6B7280" 
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ToolTip>
            </Border.ToolTip>
        </Border>
    </Grid>
</UserControl>
