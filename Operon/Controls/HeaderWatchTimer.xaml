<UserControl x:Class="SystemActivityTracker.Controls.HeaderWatchTimer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             VerticalAlignment="Center">
    <UserControl.Resources>
        <Style x:Key="WatchDigitStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHeaderTimerLive}" Value="True">
                    <Setter Property="Foreground" Value="#6EE7B7"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#10B981" BlurRadius="6" ShadowDepth="0" Opacity="0.85"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchColonStyle" TargetType="TextBlock" BasedOn="{StaticResource WatchDigitStyle}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHeaderTimerLive}" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="ColonBlinkStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.2" Duration="0:0:0.8"
                                                 AutoReverse="True">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ColonBlinkStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border x:Name="WatchFrame" CornerRadius="10" Padding="12,6" Margin="0,0,10,0"
            BorderThickness="1.5" SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E293B" Offset="0"/>
                <GradientStop Color="#0F172A" Offset="0.55"/>
                <GradientStop Color="#111827" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#475569"/>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.35" Direction="270"/>
        </Border.Effect>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsHeaderTimerLive}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Name="WatchPulseStoryboard">
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                     From="0.35" To="0.65" Duration="0:0:1.2" AutoReverse="True">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                    To="#10B981" Duration="0:0:0.4"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <StopStoryboard BeginStoryboardName="WatchPulseStoryboard"/>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                    To="#475569" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsTrackingRunning}" Value="False">
                        <Setter Property="Opacity" Value="0.72"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Ellipse Width="5" Height="5" Fill="#64748B" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-4,-2,0,0"/>
            <Ellipse Width="5" Height="5" Fill="#64748B" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-4,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding HeaderTimerHours}" Style="{StaticResource WatchDigitStyle}"/>
                <TextBlock Text=":" Style="{StaticResource WatchColonStyle}"/>
                <TextBlock Text="{Binding HeaderTimerMinutes}" Style="{StaticResource WatchDigitStyle}"/>
                <TextBlock Text=":" Style="{StaticResource WatchColonStyle}"/>
                <TextBlock x:Name="SecondsText" Text="{Binding HeaderTimerSeconds}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource WatchDigitStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHeaderTimerLive}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 From="1" To="1.06" Duration="0:0:0.35" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="1" To="1.06" Duration="0:0:0.35" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
